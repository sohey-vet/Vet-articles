@echo off
setlocal
chcp 65001 >nul

echo =========================================================
echo Noteの下書きを自動公開しています...
echo =========================================================
cd /d "%~dp0"

:: 仮想環境のアクティベート
call ..\.venv\Scripts\activate.bat

:: 自動投稿スクリプトの実行（当日日付）
python publish_note_daily_draft.py

echo.
echo =========================================================
echo 処理が完了しました。ログは logs フォルダを確認してください。
echo =========================================================
:: タスクスケジューラからの実行時は自動で閉じるためTimeoutを活用
timeout /t 5
endlocal
